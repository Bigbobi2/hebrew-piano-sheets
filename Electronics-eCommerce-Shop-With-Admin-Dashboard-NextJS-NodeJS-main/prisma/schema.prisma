// This is your Prisma schema file
// Finalized for Piano Sheet Music Marketplace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  artist      String?
  id          String   @id @default(uuid())
  slug        String   @unique   // e.g., "somewhere-only-we-know-piano"
  title       String             // e.g., "Somewhere Only We Know"
  mainImage   String             // Path to the sheet music preview (e.g., /sheets/song_page_1.png)
  price       Float              // e.g., 20.0
  rating      Float?   @default(0)
  description String?  @db.Text  // For arrangement or composer details
  
  // Sheet Music Specifics
  scoring     String?            // e.g., "Piano Solo"
  instruments String?            // e.g., "Piano"
  pages       Int?     @default(1)
  difficulty  String?            // e.g., "קל", "מתקדם", "קשה"

  // Relations
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  
  wishlists               Wishlist[]
  customer_order_products customer_order_product[]
}

model Category {
  id       String    @id @default(uuid())
  products Product[]
}

model User {
  id       String     @id @default(uuid())
  email    String     @unique
  password String?
  role     String?    @default("user")
  Wishlist Wishlist[]
}

model Wishlist {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model Customer_order {
  id       String                   @id @default(uuid())
  email    String
  total    Int
  status   String                   @default("PENDING")
  products customer_order_product[]
}

model customer_order_product {
  id              String         @id @default(uuid())
  customerOrder   Customer_order @relation(fields: [customerOrderId], references: [id])
  customerOrderId String
  product         Product        @relation(fields: [productId], references: [id])
  productId       String
  quantity        Int
}