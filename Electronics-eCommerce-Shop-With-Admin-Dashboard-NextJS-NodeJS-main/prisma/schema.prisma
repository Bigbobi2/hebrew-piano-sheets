// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// THE CLEANED PRODUCT MODEL
model Product {
  id           String   @id @default(uuid())
  slug         String   @unique   // e.g., "wonderful-tonight-electric"
  title        String             // e.g., "Wonderful Tonight [electric]"
  mainImage    String             // Path to your sheet music preview
  price        Float              // e.g., 20.0
  rating       Float?   @default(0)
  description  String?  @db.Text   // For the "Arrangement" details
  
  // Scoring & Instrument info (To match your Musicnotes screenshot)
  scoring      String?            // e.g., "Guitar TAB"
  instruments  String?            // e.g., "Guitar or Electric Guitar"
  pages        Int?     @default(1)

  // Minimal relations (Required for the site to function)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  
  wishlists               Wishlist[]
  customer_order_products customer_order_product[]
}

model Category {
  id       String    @id @default(uuid())
  products Product[]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String?
  role          String?        @default("user")
  Wishlist      Wishlist[]
}

model Wishlist {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model Customer_order {
  id        String                   @id @default(uuid())
  email     String
  total     Int
  status    String                   @default("PENDING")
  products  customer_order_product[]
}

model customer_order_product {
  id              String         @id @default(uuid())
  customerOrder   Customer_order @relation(fields: [customerOrderId], references: [id])
  customerOrderId String
  product         Product        @relation(fields: [productId], references: [id])
  productId       String
  quantity        Int
}